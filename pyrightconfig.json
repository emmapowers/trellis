{
  "include": ["src/trellis", "examples"],
  "exclude": [
    "docs/",
    "**/dist/",
    "**/.trellis-build/",
    "**/.workspace/",
    "**/.trellis/",
    "**/node_modules/"
  ],
  "pythonVersion": "3.13",
  "typeCheckingMode": "standard",
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": "warning",
  "executionEnvironments": [
    {
      "root": "src/trellis/platforms/desktop",
      "reportMissingImports": false
    },
    {
      "root": "src/trellis/desktop",
      "reportMissingImports": false
    },
    {
      "root": "src/trellis/packaging",
      "reportMissingImports": false
    }
  ]
}
