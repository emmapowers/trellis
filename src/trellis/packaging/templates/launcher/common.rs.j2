// Shared launcher utilities for {{ product_name }}.

use std::fs;
use std::io::{self, Read, Seek, SeekFrom};
use std::path::Path;

use sha2::{Sha256, Digest};
use windows_sys::Win32::Foundation::HWND;
use windows_sys::Win32::System::LibraryLoader::GetModuleHandleW;
use windows_sys::Win32::UI::Controls::{InitCommonControlsEx, INITCOMMONCONTROLSEX, ICC_PROGRESS_CLASS};
use windows_sys::Win32::UI::WindowsAndMessaging::{
    CreateWindowExW, DefWindowProcW, DestroyWindow, DispatchMessageW,
    MessageBoxW, PeekMessageW, RegisterClassExW, SendMessageW, ShowWindow, TranslateMessage,
    UpdateWindow, CW_USEDEFAULT, MB_ICONERROR, MSG, PM_REMOVE,
    SW_SHOWNORMAL, WNDCLASSEXW, WS_CAPTION, WS_CHILD, WS_OVERLAPPED, WS_SYSMENU, WS_VISIBLE,
};

const MAGIC: &[u8; 8] = b"TRLSPACK";
const FOOTER_SIZE: u64 = 48; // 32 hex hash + 8 archive size + 8 magic

pub struct Footer {
    pub hash: String,
    pub archive_size: u64,
}

fn wide(s: &str) -> Vec<u16> {
    s.encode_utf16().chain(std::iter::once(0)).collect()
}

pub fn show_error(msg: &str) -> ! {
    let text = wide(msg);
    let caption = wide("{{ product_name }}");
    unsafe { MessageBoxW(0, text.as_ptr(), caption.as_ptr(), MB_ICONERROR) };
    std::process::exit(1);
}

#[allow(dead_code)]
pub fn show_info(msg: &str) {
    let text = wide(msg);
    let caption = wide("{{ product_name }}");
    unsafe { MessageBoxW(0, text.as_ptr(), caption.as_ptr(), 0x40) }; // MB_ICONINFORMATION
}

pub fn read_footer(exe_path: &Path) -> Result<Footer, String> {
    let mut f = fs::File::open(exe_path).map_err(|e| format!("open self: {e}"))?;
    let file_len = f.metadata().map_err(|e| format!("metadata: {e}"))?.len();
    if file_len < FOOTER_SIZE {
        return Err("file too small".into());
    }
    f.seek(SeekFrom::End(-(FOOTER_SIZE as i64)))
        .map_err(|e| format!("seek: {e}"))?;

    let mut buf = [0u8; FOOTER_SIZE as usize];
    f.read_exact(&mut buf)
        .map_err(|e| format!("read footer: {e}"))?;

    if &buf[40..48] != MAGIC {
        return Err("magic mismatch".into());
    }

    let hash = std::str::from_utf8(&buf[0..32])
        .map_err(|_| "invalid hash")?
        .to_string();
    if hash.len() != 32 || !hash.chars().all(|c| c.is_ascii_hexdigit()) {
        return Err("invalid hash: expected 32 hex characters".into());
    }
    let archive_size = u64::from_le_bytes(buf[32..40].try_into().unwrap());
    if archive_size == 0 || archive_size > file_len - FOOTER_SIZE {
        return Err("invalid archive size".into());
    }

    Ok(Footer { hash, archive_size })
}

pub fn extract_archive(exe_path: &Path, footer: &Footer, dest: &Path, title: &str) -> Result<(), String> {
    let mut f = fs::File::open(exe_path).map_err(|e| format!("open self: {e}"))?;
    let file_len = f.metadata().map_err(|e| format!("metadata: {e}"))?.len();
    let archive_start = file_len - FOOTER_SIZE - footer.archive_size;

    f.seek(SeekFrom::Start(archive_start))
        .map_err(|e| format!("seek: {e}"))?;

    let mut archive_data = vec![0u8; footer.archive_size as usize];
    f.read_exact(&mut archive_data)
        .map_err(|e| format!("read archive: {e}"))?;

    let computed = format!("{:x}", Sha256::digest(&archive_data));
    if &computed[..32] != footer.hash {
        return Err("archive integrity check failed: hash mismatch".into());
    }

    // Decompress zstd-wrapped zip
    let zip_data = zstd::bulk::decompress(&archive_data, 512 * 1024 * 1024)
        .map_err(|e| format!("zstd decompress: {e}"))?;
    let cursor = io::Cursor::new(zip_data);
    let mut archive = zip::ZipArchive::new(cursor).map_err(|e| format!("open zip: {e}"))?;

    let total = archive.len();
    let (hwnd, progress) = create_progress_window(total as u32, title);

    for i in 0..total {
        let mut entry = archive.by_index(i).map_err(|e| format!("zip entry: {e}"))?;
        let name = entry.name().to_string();
        if name.contains("..") || name.starts_with('/') || name.starts_with('\\') || name.contains(':') {
            return Err(format!("zip entry contains path traversal: {name}"));
        }
        let out_path = dest.join(&name);

        if entry.is_dir() {
            fs::create_dir_all(&out_path).map_err(|e| format!("mkdir {name}: {e}"))?;
        } else {
            if let Some(parent) = out_path.parent() {
                fs::create_dir_all(parent).map_err(|e| format!("mkdir parent: {e}"))?;
            }
            let mut out_file =
                fs::File::create(&out_path).map_err(|e| format!("create {name}: {e}"))?;
            io::copy(&mut entry, &mut out_file).map_err(|e| format!("write {name}: {e}"))?;
        }
        update_progress(progress, i as u32 + 1);
    }

    destroy_progress_window(hwnd);
    Ok(())
}

// --- Win32 progress window ---

unsafe extern "system" fn wnd_proc(hwnd: HWND, msg: u32, wp: usize, lp: isize) -> isize {
    DefWindowProcW(hwnd, msg, wp, lp)
}

fn create_progress_window(total: u32, title: &str) -> (HWND, HWND) {
    unsafe {
        let icc = INITCOMMONCONTROLSEX {
            dwSize: std::mem::size_of::<INITCOMMONCONTROLSEX>() as u32,
            dwICC: ICC_PROGRESS_CLASS,
        };
        InitCommonControlsEx(&icc);

        let instance = GetModuleHandleW(std::ptr::null());
        let class_name = wide("TrlsLauncher");
        let wc = WNDCLASSEXW {
            cbSize: std::mem::size_of::<WNDCLASSEXW>() as u32,
            style: 0,
            lpfnWndProc: Some(wnd_proc),
            cbClsExtra: 0,
            cbWndExtra: 0,
            hInstance: instance,
            hIcon: 0,
            hCursor: 0,
            hbrBackground: (5 + 1) as _, // COLOR_WINDOW + 1
            lpszMenuName: std::ptr::null(),
            lpszClassName: class_name.as_ptr(),
            hIconSm: 0,
        };
        RegisterClassExW(&wc);

        let style = WS_OVERLAPPED | WS_CAPTION | WS_SYSMENU;
        let title_w = wide(title);
        let hwnd = CreateWindowExW(
            0,
            class_name.as_ptr(),
            title_w.as_ptr(),
            style,
            CW_USEDEFAULT, CW_USEDEFAULT,
            420, 80,
            0,
            0,
            instance,
            std::ptr::null(),
        );

        let progress_class = wide("msctls_progress32");
        let progress = CreateWindowExW(
            0,
            progress_class.as_ptr(),
            std::ptr::null(),
            WS_CHILD | WS_VISIBLE,
            10, 10, 385, 25,
            hwnd,
            0,
            instance,
            std::ptr::null(),
        );

        // PBM_SETRANGE32 = 0x0406
        SendMessageW(progress, 0x0406, 0, total as isize);

        ShowWindow(hwnd, SW_SHOWNORMAL as i32);
        UpdateWindow(hwnd);

        (hwnd, progress)
    }
}

fn update_progress(progress: HWND, pos: u32) {
    unsafe {
        // PBM_SETPOS = 0x0402
        SendMessageW(progress, 0x0402, pos as usize, 0);

        let mut msg: MSG = std::mem::zeroed();
        while PeekMessageW(&mut msg, 0, 0, 0, PM_REMOVE) != 0 {
            TranslateMessage(&msg);
            DispatchMessageW(&msg);
        }
    }
}

fn destroy_progress_window(hwnd: HWND) {
    unsafe {
        DestroyWindow(hwnd);
    }
}

// --- Lock file ---

pub fn acquire_lock(lock_path: &Path) -> Result<fs::File, String> {
    fs::create_dir_all(lock_path.parent().unwrap())
        .map_err(|e| format!("create lock dir: {e}"))?;

    for _ in 0..300 {
        match fs::OpenOptions::new()
            .write(true)
            .create_new(true)
            .open(lock_path)
        {
            Ok(f) => return Ok(f),
            Err(e) if e.kind() == io::ErrorKind::AlreadyExists => {
                std::thread::sleep(std::time::Duration::from_millis(100));
            }
            Err(e) => return Err(format!("lock: {e}")),
        }
    }
    Err("timeout waiting for lock".into())
}

pub fn release_lock(lock_file: fs::File, lock_path: &Path) {
    drop(lock_file);
    let _ = fs::remove_file(lock_path);
}
