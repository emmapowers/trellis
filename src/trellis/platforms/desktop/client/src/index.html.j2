<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title | default('Trellis App') }}</title>
    {% if has_icon %}
    <link rel="icon" type="{{ favicon_type }}" href="{{ favicon_href }}">
    {% if apple_touch_icon_href %}
    <link rel="apple-touch-icon" href="{{ apple_touch_icon_href }}">
    {% endif %}
    {% endif %}
    <link rel="stylesheet" href="bundle.css">
    <script>
        // Early theme detection to prevent flash of wrong theme
        (function() {
            var theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            document.documentElement.dataset.theme = theme;
        })();
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body, #root { margin: 0; padding: 0; height: 100%; min-height: 100vh; }
    </style>
</head>
<body>
    <div id="root" class="trellis-root">
    {% if ssr_enabled %}
        <template id="ssr-light">{{ ssr_light_html | safe }}</template>
        <template id="ssr-dark">{{ ssr_dark_html | safe }}</template>
    {% endif %}
    </div>
    <script>
        function renderFatalError(title, details) {
            var pre = document.createElement('pre');
            pre.style.cssText = 'color:red;padding:20px';
            pre.textContent = title + '\n' + details;
            document.body.textContent = '';
            document.body.appendChild(pre);
        }
        window.onerror = function(msg, url, line, col, err) {
            renderFatalError('ERROR: ' + msg, url + ':' + line + ':' + col + '\n' + (err && err.stack || ''));
        };
        window.addEventListener('unhandledrejection', function(e) {
            renderFatalError('UNHANDLED REJECTION: ' + e.reason, (e.reason && e.reason.stack || ''));
        });
    </script>
    {% if ssr_enabled %}
    <script>
        // Select the correct SSR theme variant before first paint.
        // SSR HTML is trusted build-time content from the app's renderToString.
        (function() {
            var isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            var templateId = isDark ? 'ssr-dark' : 'ssr-light';
            var template = document.getElementById(templateId);
            var root = document.getElementById('root');
            if (template && root) {
                // Replace all children with the selected SSR template content.
                // This also removes the <template> elements inside #root.
                while (root.firstChild) root.removeChild(root.firstChild);
                var clone = document.importNode(template.content, true);
                root.appendChild(clone);
            }
        })();
    </script>
    <script>
        // Set dehydration data for the active theme
        (function() {
            var isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            var lightData = {{ ssr_light_data | safe }};
            var darkData = {{ ssr_dark_data | safe }};
            window.__TRELLIS_SSR__ = isDark ? darkData : lightData;
        })();
    </script>
    {% endif %}
    <script type="module" src="bundle.js"></script>
</body>
</html>
