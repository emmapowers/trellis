from trellis import App, component
from trellis import html as h


@component
def Root():
    with h.Main(
        style={
            "minHeight": "100vh",
            "display": "flex",
            "alignItems": "center",
            "justifyContent": "center",
            "padding": "32px",
        }
    ):
        with h.Section(style={"maxWidth": "640px", "width": "100%", "textAlign": "center"}):
            h.H1("Welcome to {{ title }}")
            h.P("Your project is set up. Start building from here.")
            with h.P():
                h.A("Read the docs", href="https://emmapowers.github.io/trellis/")


app = App(Root)
